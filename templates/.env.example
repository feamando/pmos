# PM-OS Environment Configuration
# Copy this file to user/.env and fill in your values
# IMPORTANT: Never commit .env to git

# ============================================
# GOOGLE WORKSPACE (Required for GDocs/Calendar)
# ============================================
# Setup Guide:
# 1. Go to https://console.cloud.google.com
# 2. Create project and enable Gmail, Drive, Calendar APIs
# 3. Create OAuth 2.0 credentials (Desktop app type)
# 4. Download client_secret.json to user/.secrets/

# Optional: Override default credential paths
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# GOOGLE_TOKEN_PATH=path/to/token.json

# ============================================
# JIRA (Required for /sync jira)
# ============================================
# Get API token from: https://id.atlassian.com/manage/api-tokens

JIRA_SERVER=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECTS=PROJ1,PROJ2

# ============================================
# GITHUB (Optional - for /sync github)
# ============================================
# Get token from: https://github.com/settings/tokens
# Required scopes: repo (read)

GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_REPOS=org/repo1,org/repo2

# ============================================
# SLACK (Optional - for Slack context)
# ============================================
# Create app at: https://api.slack.com/apps
# Required scopes: channels:history, channels:read, users:read, groups:history, groups:read

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNELS=general,engineering,product-team

# Channel tiers for bulk extraction
SLACK_TIER1_CHANNELS=product-team,engineering-leads
SLACK_TIER2_CHANNELS=engineering,design,weekly-sync

# Channel for posting context summaries
# Required scope: chat:write
SLACK_POST_CHANNEL=your-channel-id

# Bot User ID for mention capture
# Find via: Slack profile > ... > Copy member ID
SLACK_BOT_USER_ID=U0XXXXXXXXX

# ============================================
# CONFLUENCE (Optional)
# ============================================
# Uses same Atlassian API token as Jira

CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_SPACES=ENG,PROD

# ============================================
# GEMINI (Optional - for meeting transcription)
# ============================================
# Get API key from: https://makersuite.google.com/app/apikey

GEMINI_API_KEY=your-gemini-api-key

# ============================================
# STATSIG (Optional - for experiment tracking)
# ============================================

STATSIG_API_KEY=secret-your-statsig-key
STATSIG_PROJECT_ID=your-project-id

# ============================================
# CALENDAR (Optional - for meeting prep)
# ============================================
# Uses Google Calendar API (same OAuth as GDocs)

CALENDAR_LOOKAHEAD_HOURS=12

# ============================================
# DEBUG OPTIONS
# ============================================

# Enable verbose logging
# DEBUG=true

# Dry run mode (no writes)
# DRY_RUN=true
