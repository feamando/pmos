{
  "name": "pm-os-app",
  "version": "0.10.0",
  "description": "PM-OS Connections Manager — manage PM-OS integrations",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "bundle": "bash scripts/bundle-pmos.sh",
    "package": "electron-builder",
    "dist": "npm run bundle && npm run build && electron-builder --mac",
    "dist:dev": "npm run bundle && npm run build && electron-builder --mac --dir"
  },
  "author": "feamando",
  "license": "MIT",
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "electron-store": "^11.0.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
