{
  "calendar_id": "primary",
  "lookahead_hours": 12,
  "output_dir": "Planning/Meeting_Prep",
  "archive_dir": "Planning/Meeting_Prep/Archive",
  "meeting_types": {
    "1:1": {
      "keywords": ["1:1", "1-1", "one on one", "check-in"],
      "prep_template": "1on1_prep.md"
    },
    "standup": {
      "keywords": ["standup", "stand-up", "daily sync", "scrum"],
      "prep_template": "standup_prep.md"
    },
    "review": {
      "keywords": ["review", "demo", "showcase", "sprint review"],
      "prep_template": "review_prep.md"
    },
    "planning": {
      "keywords": ["planning", "grooming", "refinement", "backlog"],
      "prep_template": "planning_prep.md"
    },
    "external": {
      "keywords": ["external", "vendor", "partner", "customer"],
      "prep_template": "external_prep.md"
    }
  },
  "attendee_entity_mapping": {
    "john.smith@company.com": "Entities/John_Smith.md",
    "sarah.chen@company.com": "Entities/Sarah_Chen.md"
  },
  "exclude_patterns": [
    "OOO",
    "Blocked",
    "Focus Time",
    "Lunch"
  ]
}
